DATABASE_URL="postgresql://user:password@localhost:5432/ai_aggregator?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/ai_aggregator?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# 可选：多个正式/预览域名用英文逗号分隔，用于 CORS 和站内 API 来源判断。
# ALLOWED_ORIGINS="https://example.com,https://preview.example.com"

# 事务邮件服务，生产环境推荐 Resend SMTP + 已验证域名邮箱。
# Resend SMTP:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=your_resend_api_key
# EMAIL_FROM=noreply@mail.example.com
# EMAIL_FROM_NAME=AIHub

# 腾讯翻译 API（可选，用于 RSS 英文内容翻译）
# 申请地址：https://cloud.tencent.com/product/tmt
# 免费额度：500万字符/月
TENCENT_TRANSLATE_SECRET_ID=your_secret_id_here
TENCENT_TRANSLATE_SECRET_KEY=your_secret_key_here

# Cloudflare R2（图片存储）
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET=aihub-images
